<idea-plugin>
    <id>com.github.sendtoai</id>
    <name>Send to AI Assistant</name>
    <version>1.0.0</version>
    <vendor>okhomyk</vendor>

    <description>
        Виділи код → хоткей → текст з файлом і рядками вставляється в AI Assistant чат.
    </description>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action
            id="SendToAIAssistant"
            class="com.github.sendtoai.SendToAIAction"
            text="Send to AI Assistant Chat"
            description="Copy selected code with file context and paste into AI Assistant">

            <!-- Контекстне меню в редакторі -->
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>

            <!-- Хоткей: Option+Shift+A (macOS) / Alt+Shift+A (Win/Linux) -->
            <keyboard-shortcut
                keymap="$default"
                first-keystroke="alt shift A"/>
            <keyboard-shortcut
                keymap="Mac OS X"
                first-keystroke="alt shift A"/>
            <keyboard-shortcut
                keymap="Mac OS X 10.5+"
                first-keystroke="alt shift A"/>
        </action>
    </actions>
</idea-plugin>
